{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "proseWrap": "always",
  "semi": false,
  "printWidth": 80,
  "sortImports": true,
  "sortPackageJson": {},
  "ignorePatterns": [
    "lazy-lock.json",
    "CHANGELOG.md",
    "release-please-config.json",
    ".release-please-manifest.json",
    "pnpm-lock.yaml",
    "integration-tests/dist",
    "integration-tests/test-environment/.repro"
  ]
}
